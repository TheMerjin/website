---
import WebsiteLayout from "../../../layouts/WhiteWebsiteLayout.astro";

const pages = import.meta.glob("./**/*.astro");

function format(str: string) {
  return str
    .replaceAll("_", " ")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

const items = Object.keys(pages)
  .filter((path) => !path.endsWith("index.astro"))
  .map((path) => {
    const clean = path.replace("./", "").replace(".astro", "");
    const parts = clean.split("/");

    return {
      book: parts[0] ?? "other",
      part: parts[1] ?? "misc",
      chapter: parts[2] ?? parts[1],
      url: "/chess/solutions/" + clean,
    };
  });

const grouped: Record<string, Record<string, any[]>> = {};

for (const item of items) {
  if (!grouped[item.book]) grouped[item.book] = {};
  if (!grouped[item.book][item.part]) grouped[item.book][item.part] = [];

  grouped[item.book][item.part].push(item);
}
---

<WebsiteLayout>
  <main>

    <h1>Chess Solutions</h1>

    {Object.entries(grouped).map(([book, parts]) => (
      <section class="book">
        <h2>{format(book)}</h2>

        {Object.entries(parts).map(([part, chapters]) => (
          <div class="part">
            <h3>{format(part)}</h3>

            <div class="grid">
              {chapters.map((c) => (
                <a href={c.url} class="card">
                  <span>{format(c.chapter)}</span>
                </a>
              ))}
            </div>
          </div>
        ))}

      </section>
    ))}

  </main>

  <style>
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
      font-family: system-ui, -apple-system, sans-serif;
      color: #000;
    }

    h1 {
      font-size: 2.2rem;
      margin-bottom: 2rem;
    }

    h2 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    h3 {
      font-size: 1.1rem;
      margin-bottom: 0.8rem;
      opacity: 0.7;
    }

    .book {
      margin-bottom: 2.5rem;
    }

    .part {
      margin-bottom: 1.8rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0.8rem;
    }

    .card {
      display: block;
      padding: 0.9rem 1rem;
      border: 1px solid #000;
      border-radius: 10px;
      text-decoration: none;
      color: #000;
      transition: all 0.15s ease;
    }

    .card:hover {
      background: #000;
      color: #fff;
      transform: translateY(-2px);
    }

    .card span {
      font-size: 0.95rem;
    }
  </style>
</WebsiteLayout>