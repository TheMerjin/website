---
import WebsiteLayout from "../../layouts/WebsiteLayout.astro";
function titleCase(s: string) {
  return s
    .split(/[\s_-]+/g)
    .filter(Boolean)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}
function cleanSegment(seg: string) {
  try {
    return decodeURIComponent(seg);
  } catch {
    return seg;
  }
}
function titleFromRoute(route: string) {
  const parts = route.split("/").filter(Boolean).map(cleanSegment);
  if (parts.length === 0) return "Math";
  const last = parts[parts.length - 1];
  return titleCase(last);
}
// Discover all math pages (excluding this index).
const modules = import.meta.glob("./**/*.astro", { eager: true });
const routes = Object.keys(modules)
  .map((p) => p.replace(/^\.\/+/, "")) // "differential equations/foo.astro"
  .filter((p) => p.toLowerCase() !== "index.astro")
  .map((p) => p.replace(/\.astro$/i, "")); // "differential equations/foo"
const entries = routes
  .map((r) => ({
    route: `/math/${r.split("/").map(encodeURIComponent).join("/")}`,
    title: titleFromRoute(r),
    section: r.includes("/") ? titleCase(cleanSegment(r.split("/")[0])) : "Notes",
  }))
  .sort((a, b) => a.route.localeCompare(b.route));

const sections = Array.from(new Set(entries.map((e) => e.section)));
---

<WebsiteLayout>
  <main class="math-index">
    <header class="math-head">
      <h1>Math</h1>
      <p class="lead">
        Notes, sketches, and worked examples.
      </p>
    </header>

    {entries.length === 0 ? (
      <p class="empty">No math pages yet.</p>
    ) : (
      sections.map((section) => (
        <section class="block">
          <h3>{section}</h3>
          <ul class="list" role="list">
            {entries
              .filter((e) => e.section === section)
              .map((e) => (
                <li class="item">
                  <a class="item-link" href={e.route}>
                    <h4 class="item-title">{e.title}</h4>
                  </a>
                  <small class="item-meta">
                    <code class="path">{e.route}</code>
                  </small>
                </li>
              ))}
          </ul>
        </section>
      ))
    )}

  </main>
</WebsiteLayout>

<style>
  :global(:root) {
    --color-text: #000;
    --blue: #337ab3;
  }

  .math-index {
    max-width: 70ch;
    margin: 0 auto;
    padding: 0 1rem;
    color: var(--color-text);
    font-family: system-ui, sans-serif;
    line-height: 1.6;
  }

  .math-head h1 {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
    padding: 0;
  }

  .lead {
    margin: 0.5rem 0 0;
    color: #444;
  }

  .block {
    margin: 1.25rem 0 0;
  }

  .block h2 {
    font-size: 1.02rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid #d1d5db;
  }

  .item:last-child {
    border-bottom: none;
  }

  .item-link {
    color: var(--color-text);
    text-decoration: none;
    flex: 1;
    min-width: 10ch;
  }

  .item-link:hover {
    text-decoration: underline;
  }

  .item-title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    padding: 0;
    display: inline;
    color: var(--color-text);
  }

  .item-meta {
    color: #444;
    white-space: nowrap;
  }

  .path {
    font-family: Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
    font-size: 0.82rem;
    color: #444;
    background: transparent;
    border: none;
    padding: 0;
  }

  .empty {
    color: #666;
    margin: 0;
  }

  .foot {
    margin-top: 2rem;
    color: #666;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* Keep link styling consistent with the Uli-ish snippet */
  .math-index a {
    color: var(--blue);
    text-decoration: none;
    text-decoration-skip-ink: auto;
  }
  .math-index a:hover {
    text-decoration: underline;
  }
</style>

