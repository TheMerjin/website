---
import katex from "katex";
import "katex/dist/katex.min.css";


// Example equations
const eq1 = "y = mx + b";
const eq2 = "f(x) = \\sum_{n=0}^{\\infty} \\frac{f^{(n)}(a)}{n!} (x-a)^n";
const eq3 = "\\frac{dy}{dx} = x - y";

const K = (latex: string) => katex.renderToString(latex, { throwOnError: false });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Math Exercises</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body {
        margin: 0;
        padding: 3rem 1.2rem;
        max-width: 820px;
        margin-left: auto;
        margin-right: auto;
        font-family: serif;
        background: #fafafa;
        color: #111;
        line-height: 1.55;
