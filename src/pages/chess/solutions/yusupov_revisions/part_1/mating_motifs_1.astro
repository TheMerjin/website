<style>
main {
  max-width: 720px;
  margin: 0 auto;
  padding: 2rem 1rem;
  font-family: system-ui, -apple-system, sans-serif;
  line-height: 1.65;
  color: #000;
}

/* Title */
h1 {
  font-size: 2rem;
  margin-bottom: 1.5rem;
}

/* Sections */
.section {
  margin-bottom: 2rem;
}

/* Remove bullets completely */
ul {
  list-style: none;
  padding-left: 0;
  margin: 0;
}

li {
  margin-bottom: 1rem;
}

/* Indented blocks instead of bullets */
.indent {
  margin-left: 1rem;
}

/* Math spacing */
.math-block {
  display: block;
  margin: 0.4rem 0;
}

/* Clean solution block */
.solution {
  border-left: 3px solid #000;
  padding-left: 0.8rem;
  margin-top: 0.6rem;
}

/* Slight emphasis */
strong {
  font-weight: 600;
}
</style>


