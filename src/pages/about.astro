---
import WebsiteGraph from "../components/websiteGraph.jsx";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>About — Sreek</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
      /* -----------------------------
         Gwern-style base system
      ------------------------------ */

      body {
        margin: 0;
        max-width: 820px;
        margin-left: auto;
        margin-right: auto;
        padding: 3rem 1.2rem;
        font-family: serif;
        background: #fafafa;
        color: #111;
        line-height: 1.55;
      }

      a {
        color: #000;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      /* header metadata line */
      .meta {
        font-family: monospace;
        font-size: 11px;
        opacity: 0.6;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
      }

      h1 {
        font-size: 2.4rem;
        margin: 0.5rem 0 1rem;
      }

      .subtitle {
        font-style: italic;
        opacity: 0.75;
        margin-bottom: 2rem;
      }

      /* content blocks */
      section {
        margin-bottom: 2rem;
      }

      ul {
        padding-left: 1.2rem;
      }

      li {
        margin-bottom: 0.6rem;
      }

      /* graph section */
      h2 {
        font-size: 1.1rem;
        margin-top: 2rem;
        margin-bottom: 0.3rem;
      }

      .lead {
        font-size: 0.95rem;
        opacity: 0.75;
        max-width: 65ch;
        margin-bottom: 1rem;
      }

      /* side note style (Gwern marginalia) */
      .note {
        margin-top: 3rem;
        padding-left: 1rem;
        border-left: 2px solid #ddd;
        font-style: italic;
        opacity: 0.8;
      }

      footer {
        margin-top: 4rem;
        font-family: monospace;
        font-size: 10px;
        opacity: 0.5;
        border-top: 1px solid #ddd;
        padding-top: 1rem;
        display: flex;
        justify-content: space-between;
      }

      @media (max-width: 600px) {
        h1 {
          font-size: 2rem;
        }

        footer {
          flex-direction: column;
          gap: 0.5rem;
        }
      }
    </style>
  </head>

  <body>

    <!-- metadata header -->
    <div class="meta">
      C:\site\sreek\about.astro •
      static document •
      status: live
    </div>

    <h1>About</h1>

    <div class="subtitle">
      Notes, links, and a partial map of this site.
    </div>

    <!-- main content -->
    <main>

      <section>
        <p>
          Some things about me.
        </p>

        <ul>
          <li>
            I like reading books; my reading list with reviews is available
            <a href="/books/have-read">here</a>.
          </li>

          <li>
            My <a href="/blog">blog</a> is hosted here, alongside a
            <a href="/">public forum</a> where discussion is open.
          </li>
        </ul>
      </section>

      <!-- graph section -->
      <section>
        <h2>Site link graph</h2>

        <p class="lead">
          Crawled link structure (paths are route IDs: pathname + query + hash).
          Use the page links view for a searchable outbound index.
        </p>

        <WebsiteGraph client:load />
      </section>

    </main>

    <!-- marginal note -->
    <aside class="note">
      The structure of a website is often more interesting than its content.
      Navigation is itself a form of reading.
    </aside>

    <!-- footer -->
    <footer>
      <span>archive: active</span>
      <span>graph: client-rendered</span>
      <span>render: SSR hybrid</span>
    </footer>

  </body>
</html>