---
import WebsiteLayout from "../../layouts/WhiteWebsiteLayout.astro";
import { marked } from "marked";
import markedKatex from "marked-katex-extension";
import createDOMPurify from "dompurify";
import { JSDOM } from "jsdom";
import CommentsTree from "../../components/CommentsTree.jsx";

export const prerender = false;

const { slug } = Astro.params;

// Fetch posts
const res = await fetch(`${import.meta.env.PUBLIC_API_URL}api/auth/get_posts`);
const { posts } = await res.json();

// Find the correct post
const correctPost = posts.find((post) => post.id == slug);

// Setup DOMPurify
const window = new JSDOM("").window;
const DOMPurify = createDOMPurify(window);

// KaTeX
marked.use(markedKatex({
  throwOnError: false,
  displayMode: true,
}));


function extractFootnotes(text) {
  const lines = text.split("\n");
  const footnotes = {};

  let currentId = null;
  let buffer = [];

  for (const line of lines) {
    const match = line.match(/^\[\^(\d+)\]:\s*(.*)/);

    if (match) {
      if (currentId !== null) {
        footnotes[currentId] = buffer.join("\n").trim();
      }

      currentId = match[1];
      buffer = [match[2]];
    } else if (currentId !== null && line.trim() !== "") {
      buffer.push(line);
    }
  }

  if (currentId !== null) {
    footnotes[currentId] = buffer.join("\n").trim();
  }

  return footnotes;
}

/* -----------------------------
   NORMALIZE INLINE REFERENCES
   [1] → [^1]
------------------------------*/
const normalizedContent = correctPost.content.replace(/\[(\d+)\]/g, "[^$1]");

/* -----------------------------
   INJECT FOOTNOTE LINKS
------------------------------*/
function injectFootnoteLinks(html) {
  return html.replace(
    /<sup>(\d+)<\/sup>/g,
    (_, id) =>
      `<a id="ref-${id}" href="#fn-${id}" class="footnote-ref">[${id}]</a>`
  );
}

/* -----------------------------
   PROCESS FOOTNOTES
------------------------------*/
const footNotes = extractFootnotes(normalizedContent);

const footnotesHTML = Object.keys(footNotes)
  .sort((a, b) => Number(a) - Number(b))
  .map((id) => ({
    id,
    html: marked.parse(footNotes[id]),
  }));

/* -----------------------------
   MARKDOWN → HTML
------------------------------*/
const rawHtml = injectFootnoteLinks(
  marked.parse(normalizedContent)
);

const safeHtml = DOMPurify.sanitize(rawHtml, {
  ADD_TAGS: [
    "math",
    "mi",
    "mo",
    "mn",
    "mrow",
    "annotation",
  ],
  ADD_ATTR: [
    "display",
    "id",
    "href",
    "class",
  ],
});

/* -----------------------------
   DATE
------------------------------*/
const date = new Date(correctPost.created_at).toLocaleDateString(undefined, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<WebsiteLayout>
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css"
    />
    <style>
      html {
        scroll-behavior: smooth;
      }
    </style>
  </head>

  <div class="page">
    <article class="post">
      <h1 class="title">{correctPost.title}</h1>

      <div class="byline">
        By <a href={`/${correctPost.username}`} class="author-link">
          {correctPost.username}
        </a> on {date}
      </div>

      <div class="content" set:html={safeHtml}></div>
    </article>

    <aside class="sideNotes">
      {footnotesHTML.map((note) => (
        <div class="sidenote" id={`fn-${note.id}`}>
          <a class="sidenote-num" href={`#ref-${note.id}`}>
            [{note.id}]
          </a>
          <span
            class="sidenote-body"
            set:html={note.html}
          />
        </div>
      ))}
    </aside>
  </div>

  <div class="comments">
    <CommentsTree slug={slug} client:load />
  </div>
</WebsiteLayout>