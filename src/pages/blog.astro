---
import WebsiteLayout from '../layouts/WebsiteLayout.astro';
import PostCard from '../components/PostCard.astro';
import { supabase } from '../lib/supabase.js';

export const prerender = false;

// Fetch all posts from user "Sreek"
let sreekPosts = [];
let error = null;

try {
  // First get the user profile to get the user_id
  const { data: profileData, error: profileError } = await supabase
    .from('profiles')
    .select('id')
    .eq('username', 'Sreek')
    .single();

  if (profileError || !profileData) {
    error = 'User Sreek not found';
  } else {
    // Now get the posts for this user
    const { data: postsData, error: postsError } = await supabase
      .from('posts')
      .select('*')
      .eq('author_id', profileData.id)
      .order('created_at', { ascending: false });

    if (!postsError) {
      sreekPosts = postsData || [];
    } else {
      error = 'Failed to load posts';
    }
  }
} catch (err) {
  error = 'Failed to load blog';
}
---

<WebsiteLayout>
  <main> 
  <div class="blog-container">
    <div class="blog-header">
      <h1><a href = "/about" > Sreek's</a> Blog</h1>
      <p class="blog-description"></p>
    </div>

    {error ? (
      <div class="error-message">
        <h2>Error Loading Blog</h2>
        <p>{error}</p>
      </div>
    ) : sreekPosts.length === 0 ? (
      <div class="no-posts">
        <h2>No Posts Yet</h2>
        <p>Sreek hasn't published any posts yet.</p>
      </div>
    ) : (
      <div class="posts-list">
        {sreekPosts.map((post) => (
          <PostCard post={post} key={post.id} />
        ))}
      </div>
    )}
  </div>
  </main>
</WebsiteLayout>

<style>
  .blog-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0rem 1rem;
    background-color: #f8f2e4;
    min-height: 100vh;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e6e1d7;
  }

  .blog-header h1 {
    font-size: 3rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 1rem;
    font-family: 'Inter', sans-serif;
  }

  .blog-description {
    font-size: 1.2rem;
    color: #666;
    margin: 0;
  }

  .error-message {
    text-align: center;
    padding: 4rem 2rem;
  }

  .error-message h2 {
    color: #d32f2f;
    margin-bottom: 1rem;
  }

  .no-posts {
    text-align: center;
    padding: 4rem 2rem;
  }

  .no-posts h2 {
    color: #666;
    margin-bottom: 1rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0rem;
  }
  .about-graph-heading {
      font-size: 1.1rem;
      font-weight: 600;
      margin: 1.5rem 0 0.35rem;
      color: #1a1a1a;
    }
    .about-graph-lead {
      font-size: 0.95rem;
      color: #4b5563;
      margin: 0 0 1rem;
      line-height: 1.5;
      max-width: 42rem;
    }
    main a {
      color: #000;             /* black text by default */
      text-decoration: none;   /* no underline initially */
      transition: color 0.15s, text-decoration 0.15s;
    }

    main a:hover {
      color: #6b7280;          /* gray on hover */
      text-decoration: underline;
    }

  @media (max-width: 768px) {
    .blog-container {
      padding: 1rem 0.5rem;
    }

    .blog-header h1 {
      font-size: 2rem;
    }

    .blog-description {
      font-size: 1rem;
    }
  }
  .blog-header h1 a {
  color: #000;
  text-decoration: none;
}

.blog-header h1 a:hover {
  color: #6b7280;
  text-decoration: underline;
}

  @media (max-width: 480px) {
    .blog-header h1 {
      font-size: 1.5rem;
    }

    .blog-description {
      font-size: 0.9rem;
    }
  }
</style> 