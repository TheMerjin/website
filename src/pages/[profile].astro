---
import WebsiteLayout from '../layouts/WebsiteLayout.astro';
import ProfilePostCard from '../components/ProfilePostCard.astro';
import { supabase } from '../lib/supabase.js';

export const prerender = false;

const { profile } = Astro.params;
const isMath = profile === "math";

// --------------------
// PROFILE DATA
// --------------------
let userProfile = null;
let userPosts = [];
let error = null;

if (!isMath) {
  try {
    const { data: profileData, error: profileError } = await supabase
      .from('profiles')
      .select('*')
      .eq('username', profile)
      .single();

    if (profileError) {
      error = 'User not found';
    } else {
      userProfile = profileData;

      const { data: postsData, error: postsError } = await supabase
        .from('posts')
        .select('*')
        .eq('author_id', userProfile.id)
        .order('created_at', { ascending: false })
        .limit(10);

      if (!postsError) {
        userPosts = postsData || [];
      }
    }
  } catch (err) {
    error = 'Failed to load profile';
  }
}

// --------------------
// MATH ARCHIVE LOGIC
// --------------------
function titleCase(s) {
  return s
    .split(/[\s_-]+/g)
    .filter(Boolean)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

function cleanSegment(seg) {
  try {
    return decodeURIComponent(seg);
  } catch {
    return seg;
  }
}

function titleFromRoute(route) {
  const parts = route.split("/").filter(Boolean).map(cleanSegment);
  if (parts.length === 0) return "Math";
  const last = parts[parts.length - 1];
  return titleCase(last);
}

let entries = [];
let sections = [];

if (isMath) {
  const modules = import.meta.glob("./math/**/*.astro", { eager: true });

  const routes = Object.keys(modules)
    .map((p) => p.replace(/^\.\/math\//, ""))
    .filter((p) => p.toLowerCase() !== "index.astro")
    .map((p) => p.replace(/\.astro$/i, ""));

  entries = routes
    .map((r) => ({
      route: `/math/${r.split("/").map(encodeURIComponent).join("/")}`,
      title: titleFromRoute(r),
      section: r.includes("/") ? titleCase(cleanSegment(r.split("/")[0])) : "Notes",
    }))
    .sort((a, b) => a.route.localeCompare(b.route));

  sections = Array.from(new Set(entries.map((e) => e.section)));
}
---

<WebsiteLayout>
  {isMath ? (
    <main>
      <div class="meta">
        Math archive • {entries.length} pages • status: live index
      </div>

      <h1>Math Archive</h1>
      <div class="subtitle">
        Notes, sketches, and worked examples.
      </div>

      {entries.length === 0 ? (
        <section>
          <h2>Empty Archive</h2>
          <p style="font-style: italic; opacity: 0.7;">
            No math pages have yet been added.
          </p>
        </section>
      ) : (
        sections.map((section) => (
          <section>
            <h2>{section}</h2>
            <ul>
              {entries
                .filter((e) => e.section === section)
                .map((e) => (
                  <li>
                    <a href={e.route}>{e.title}</a>
                    <div class="path">{e.route}</div>
                  </li>
                ))}
            </ul>
          </section>
        ))
      )}
    </main>
  ) : (
    <div class="profile-header">
      {error ? (
        <div class="error-message">
          <h1>User Not Found</h1>
          <p>The user "{profile}" could not be found.</p>
          <a href="/" class="back-link">← Back to Home</a>
        </div>
      ) : (
        <>
          <div class="user-info">
            <h1 class="username">{userProfile.username}</h1>
            <div class="user-stats">
              <span>
                Joined:{" "}
                {new Date(userProfile.created_at).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </span>
            </div>

            <div class="header-nav">
              <a href="#posts">Posts</a><span>&bull;</span>
              <a href="#">Comments</a><span>&bull;</span>
              <a href="#">Activity</a>
            </div>
          </div>

          <div>
            <h2>Bio</h2>
            <h5 class="bio">{userProfile.bio || "No bio available."}</h5>
          </div>

          <section class="post-section" id="posts">
            <h2>Posts</h2>
            {userPosts.length === 0 ? (
              <p>No posts yet!</p>
            ) : (
              userPosts.map((post) => (
                <ProfilePostCard post={post} key={post.id} />
              ))
            )}
          </section>
        </>
      )}
    </div>
  )}
</WebsiteLayout>

<style>
  .profile-header {
    padding: 1rem 5vw;
    border-bottom: 1px solid #fff4ec;
    max-width: 100vw;
    margin-left: auto;
    margin-right: auto;
  }

  .error-message {
    text-align: center;
    padding: 4rem 2rem;
  }

  .error-message h1 {
    color: #d32f2f;
    margin-bottom: 1rem;
    font-size: 2rem;
  }

  .back-link {
    display: inline-block;
    margin-top: 1rem;
    color: #456650;
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .post-section {
    margin: 0rem;
    padding: 1rem 0rem;
  }

  h1 {
    margin: 3px 3px 0.5rem 0;
    font-size: 2rem;
  }

  .user-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1rem;
    color: #555;
  }

  .header-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    font-size: 1.2rem;
    margin-left: -0.5rem;
    gap: 0.5rem;
  }

  .header-nav a {
    text-decoration: none;
    margin: 0 0.5rem;
    color: #456650;
    font-weight: 500;
  }

  .header-nav span {
    color: #999;
  }

  .bio {
    margin: 0;
    font-weight: normal;
    color: #555;
  }

  main {
    margin: 0 auto;
    padding: 3rem 1.2rem;
    max-width: 820px;
    font-family: serif;
    background: #fafafa;
    color: #111;
    line-height: 1.55;
  }

  .meta {
    font-family: monospace;
    font-size: 11px;
    opacity: 0.6;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-style: italic;
    opacity: 0.7;
    margin-bottom: 2rem;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    padding: 0.8rem 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .path {
    font-family: monospace;
    font-size: 11px;
    opacity: 0.5;
  }
</style>