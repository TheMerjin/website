---
import WebsiteLayout from "../../layouts/WhiteWebsiteLayout.astro";

function titleCase(s: string) {
  return s
    .split(/[\s_-]+/g)
    .filter(Boolean)
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

function cleanSegment(seg: string) {
  try {
    return decodeURIComponent(seg);
  } catch {
    return seg;
  }
}

function titleFromRoute(route: string) {
  const parts = route
    .split("/")
    .filter(Boolean)
    .map(cleanSegment);

  if (parts.length === 0) return "Math";

  return titleCase(parts[parts.length - 1]);
}

// Load astro pages
const modules = import.meta.glob("./**/*.astro", { eager: true });

// Load raw files
const rawModules = import.meta.glob("./**/*.astro", {
  query: "?raw",
  import: "default",
  eager: true,
}) as Record<string, string>;

const routes = Object.keys(modules)
  .map((p) => p.replace(/^\.\/+/, "").replace(/\.astro$/i, ""))
  .filter((p) => p.toLowerCase() !== "index");


// Extract exported metadata
const entries = routes
  .map((r) => {
    const fileKey = `./${r}.astro`;

    const mod = modules[fileKey] as any;
    const raw = rawModules[fileKey] ?? "";

    const metadata = mod?.metadata ?? {};
    const summary = metadata.summary ?? null;
    console.log(r.split("/")[0]);

    const hasReview = raw.trim().length > 0;

    return {
      route: `/book_reviews/${r
        .split("/")
        .map(encodeURIComponent)
        .join("/")}`,

      title: metadata.title ?? titleFromRoute(r),

      section: r.includes("/")
        ? titleCase(cleanSegment(r.split("/")[0]))
        : "Notes",

      rating: r.split("/")[0],

      summary,

      hasSummary: !!summary,
      hasReview,
    };
  })
  .sort((a, b) => a.route.localeCompare(b.route));

const indexString = "index";

const cleanedEntries = entries.map((x) =>
  x.route.endsWith(indexString)
    ? { ...x, route: x.route.slice(0, -indexString.length) }
    : x
);

const reviews = cleanedEntries.reverse();

function reviewStatus(hasReview: boolean) {
  return hasReview ? "Completed" : "Review Not Completed";
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />

  <title>Book Reviews</title>

  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    body {
      margin: 0;
      padding: 3rem 1.2rem;

      max-width: 1000px;
      margin-left: auto;
      margin-right: auto;

      font-family: Georgia, serif;
      background: #fafafa;
      color: #111;
      line-height: 1.6;
    }

    a {
      color: #000;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    h1 {
      font-size: 2.6rem;
      font-weight: 600;
      margin: 0.5rem 0;
      text-align: center;
    }

    .subtitle {
      font-style: italic;
      opacity: 0.7;
      margin-bottom: 2rem;
      text-align: center;
    }

    .review-page {
      display: flex;
      align-items: flex-start;
      gap: 2rem;
      margin-top: 2rem;
    }

    .sidebar {
      width: 250px;
      padding: 1rem;

      font-size: 0.95rem;
      line-height: 1.5;

      background-color: #f0efef;
      border: 1px solid #ddd;

      position: static;
      top: 2rem;

      height: fit-content;
    }

    .sidebar h2 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .sidebar ul {
      list-style: none;
      padding-left: 0;
      margin: 0;
    }

    .sidebar li {
      margin-bottom: 0.5rem;
    }

    .main-content {
      flex: 1;
    }

    .review-item {
      margin-bottom: 3rem;
      scroll-margin-top: 2rem;
    }

    .review-item h3 {
      font-size: 2rem;
      margin-bottom: 0.25rem;
    }

    .review-meta {
      font-size: 0.85rem;
      color: #555;
      font-family: monospace;
      margin-bottom: 1rem;
    }

    .summary-box {
      background: #efefef;
      border-left: 3px solid #cfcfcf;

      padding: 1rem 1.2rem;
      margin-top: 1rem;

      font-size: 0.97rem;
      line-height: 1.65;
    }

    .summary-title {
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #666;
      margin-bottom: 0.7rem;

      font-family: monospace;
    }

    .summary-footer {
      margin-top: 1rem;
      font-size: 0.9rem;
    }

    .summary-footer a {
      font-weight: 600;
    }

    .no-summary {
      color: #666;
      font-style: italic;
      opacity: 0.8;
    }

    @media (max-width: 850px) {
      .review-page {
        flex-direction: column;
      }

      .sidebar {
        width: 100%;
        position: static;
      }
    }
  </style>
</head>

<body>

  <h1>Book Reviews</h1>

  <div class="subtitle">
    An incremental archive of essays, notes, and long-form fragments.
  </div>

  <div class="review-page">

    <!-- Sidebar -->
    <aside class="sidebar">
      <h2>Contents</h2>

      <ul>
        {reviews.map((r, i) => {
          const id = r.title.toLowerCase().replace(/\s+/g, "-");

          return (
            <li>
              <a href={`#${id}`}>
                {i + 1}. {r.title}
              </a>
            </li>
          );
        })}
      </ul>
    </aside>

    <!-- Main -->
    <main class="main-content">

      {reviews.map((r) => {
        const id = r.title.toLowerCase().replace(/\s+/g, "-");

        return (
          <article class="review-item" id={id}>

            <h3>{r.title}</h3>

            <div class="review-meta">
              [{reviewStatus(r.hasReview)}]
              {" · "}
              {
  r.rating
    ? (() => {
        const score = Number(r.rating.split("_")[0]);
        return "★".repeat(score) + "☆".repeat(5 - score);
      })()
    : "—"
}
            </div>

            {r.hasSummary ? (
              <div class="summary-box">

                <div class="summary-title">
                  Summary
                </div>

                <div>
                  {r.summary}
                </div>

                <div class="summary-footer">
                  <a href={r.route}>
                    Read Full Review →
                  </a>
                </div>

              </div>
            ) : (
              <div class="no-summary">
                Summary not available.
              </div>
            )}

          </article>
        );
      })}

    </main>

  </div>

</body>
</html>