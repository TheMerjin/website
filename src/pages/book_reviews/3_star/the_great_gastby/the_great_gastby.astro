---
/**
 * Great Gatsby Book Review – Gwern-style standalone
 */
const reviews = [
  {
    title: "The Great Gatsby Overview",
    year: 1925,
    summary: "This book is intresting...my first impression was to regard it as boring but it has some merit on a philsophical level. The book takes pains to point out class diffrences eg. Tom Buchanan and George Wilson and even Gatbsy and the east-eggers. Gatsby uses material excess in order to bridge social gaps especially to attact easteggers.",
    rating: 2,
    route: "/reviews/the-great-gatsby-overview"
  },
  {
    title: "Chapter 1-3",
    summary: "The first three chapters of this book is like of this book is like reading the Trial by Franz Kafka without any of the air of paranoia or inrigue. We are introduced to Nick and he's a bondman with connections to East-Egg (the part that is old-money). He rents a cheap house with a rich man Jay Gatsby that throws large parties one of which Nick attends in the third chapter. ",
    route: "/reviews/the-great-gatsby-ch1-3"
  },
  {
    title: "Chapter 4-6",

    summary: "Gatsby's past revealed, parties continue, and tensions rise.",
    route: "/reviews/the-great-gatsby-ch4-6"
  },
  {
    title: "Chapter 7-9",

    summary: "Climax and resolution, the downfall of Gatsby, and the American Dream critique.",
    route: "/reviews/the-great-gatsby-ch7-9"
  }
];


export const metadata = {
  title: "The Great Gatsby",
  author: "F.Schoot Fitzgerald",
  year: 1890,
  rating: "★★★☆☆",

  summary:
    "Uta-Jima is an idyllic town unaffected by the changes of modernization. Shinji the protagnist has a blossoming love story with the female protagonist Hatsue. The simplicity of the characters fits them into traditional japanese stereo-types and allows a simple, feel good story. The whole book was simple, and steady like the tide. ",
};

const title = metadata.title;
const author = metadata.author;
const year = metadata.year;
const rating = metadata.rating;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>The Great Gatsby – Book Review</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    body {
      margin: 0;
      padding: 3rem 1.2rem;
      max-width: 1000px;
      margin-left: auto;
      margin-right: auto;
      font-family: Georgia, serif;
      background: #fafafa;
      color: #111;
      line-height: 1.55;
    }

    a { color: #000; text-decoration: none; }
    a:hover { text-decoration: underline; }

    h1 {
      font-size: 2.6rem;
      font-weight: 600;
      margin: 0.5rem 0;
      text-align: center;
    }
    .subtitle {
      font-style: italic;
      opacity: 0.7;
      margin-bottom: 2rem;
      text-align: center;
    }

    .review-page {
      display: flex;
      gap: 2rem;
      margin-top: 2rem;
    }

    .sidebar {
      width: 220px;
      position: sticky;
      top: 2rem;
      padding: 1rem;
      border: 1px solid #ddd;
      background: #fafafa;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .sidebar h2 { font-size: 1.25rem; margin-bottom: 1rem; }
    .sidebar ul { list-style: none; padding-left: 0; margin: 0; }
    .sidebar li { margin-bottom: 0.5rem; }
    .sidebar a { color: #111; }
    .sidebar a:hover { text-decoration: underline; color: #000; }

    .main-content { flex: 1; }
    .review-item { margin-bottom: 3rem; }
    .review-item h3 { font-size: 1.5rem; margin-bottom: 0.25rem; }
    .review-meta { font-size: 0.85rem; color: #555; font-family: monospace; margin-bottom: 0.5rem; }
    .review-summary { font-style: italic; opacity: 0.8; max-width: 65ch; }
    aside.inline-sidenote {
      font-size: 0.85rem;
      color: #555;
      font-family: monospace;
      display: block;
      margin-top: 0.5rem;
      border-left: 2px solid #ddd;
      padding-left: 0.5rem;
      opacity: 0.8;
    }
  </style>
</head>
<body>

  <h1>The Great Gatsby – Book Review</h1>
  <div class="subtitle">
    Chapter-by-chapter breakdown with notes and commentary.
  </div>

  <div class="review-page">
    <!-- Sidebar -->
    <aside class="sidebar">
      <h2>Contents</h2>
      <ul>
        {reviews.map((r, i) => {
          const id = r.title.toLowerCase().replace(/\s+/g, "-");
          return <li><a href={`#${id}`}>{i+1}. {r.title}</a></li>;
        })}
      </ul>
    </aside>

    <!-- Main content -->
    <main class="main-content">
      {reviews.map((r) => {
        const id = r.title.toLowerCase().replace(/\s+/g, "-");
        return (
          <div class="review-item" id={id}>
            <h3>{r.title}</h3>
            <div class="review-meta">
              {r.year && `·` }  {r.rating && `${r.rating} Stars ·`}  <a href={r.route}>Full Review →</a>
            </div>
            <div class="review-summary">{r.summary}</div>
          </div>
        );
      })}
    </main>
  </div>

</body>
</html>