---
import WebsiteLayout from '../layouts/WebsiteLayout.astro';
import ProfilePostCard from '../components/ProfilePostCard.astro';

const res = await fetch(`${import.meta.env.PUBLIC_API_URL}api/auth/get_posts`);
const { posts } = await res.json();

// Fetch current user id
const userRes = await fetch(`${import.meta.env.PUBLIC_API_URL}api/auth/user-data`, { 
  headers: { cookie: Astro.request.headers.get('cookie') || '' } 
});
const { user } = await userRes.json();

// 1. Declare the variable out here so the whole file can see it
let profilePosts = [];

// 2. Assign the value inside the blocks without using 'const' again
if (user) {
    profilePosts = posts.filter((post: any) => post.author_id === user.id);
} else {
    profilePosts = [];
}


---

<WebsiteLayout title="Posts">
  <main class="content">
    <h1>Posts</h1>

```
{
  profilePosts.length === 0 ? (
    <p class="empty">No posts found.</p>
  ) : (
    profilePosts.map((post: any) => (
      <article class="entry">
        <a href={`/edit/${post.id}`} class="entry-title">
          {post.title || "Untitled"}
        </a>

        <div class="entry-meta">
          {post.created_at &&
            new Date(post.created_at).toUTCString()}
        </div>

        <div class="entry-preview">
          {(post.content || "")
            .replace(/\n/g, " ")
            .slice(0, 350)}
          {(post.content || "").length > 350 ? " ..." : ""}
        </div>
      </article>
    ))
  )
}


  </main>
</WebsiteLayout>

<style>
.content {
  max-width: 720px;
  margin: 3rem auto;
  padding: 0 1.5rem;
  font-family: Georgia, "Times New Roman", serif;
}

h1 {
  font-size: 2.2rem;
  font-weight: 400;
  margin-bottom: 2.5rem;
  color: #222;
}

.entry {
  margin-bottom: 2.5rem;
}

.entry-title {
  display: inline;
  font-size: 1.45rem;
  line-height: 1.3;
  font-weight: 600;
  color: #2a5885;
  text-decoration: none;
}

.entry-title:hover {
  text-decoration: underline;
}

.entry-meta {
  margin-top: 0.35rem;
  font-size: 0.85rem;
  color: #777;
}

.entry-preview {
  margin-top: 0.8rem;
  line-height: 1.75;
  color: #333;
  font-size: 1rem;
}

.empty {
  color: #777;
}

@media (max-width: 768px) {
  .content {
    padding: 0 1rem;
  }

  .entry-title {
    font-size: 1.25rem;
  }
}
</style>
